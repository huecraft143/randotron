# QRNG API key for live quantum randomness (qrngapi.com).
# Copy this file to ".env" and fill in your key.
#
# WARNING: any VITE_-prefixed variable is bundled into the client and is
# therefore PUBLIC. For production, do NOT expose the key here — instead
# call qrngapi.com from your own backend/proxy and point the app at that.
# See README "Security" section.
VITE_QRNG_API_KEY=

# Optional: route requests through your own proxy instead of calling
# qrngapi.com directly (recommended for production). Leave blank to call
# the public API directly from the browser.
VITE_QRNG_PROXY_URL=
